# Root/server environment for local development and repository scripts.
# Copy this file to .env.local at the repository root. Never commit that copy.
NODE_ENV=development
PORT=4000
# Exact browser origin; no path or trailing wildcard. HTTP is local-only.
CLIENT_URL=http://localhost:5173

# Use dedicated local/development databases. DIRECT_URL is used by Prisma
# migrations when set and otherwise falls back to DATABASE_URL.
DATABASE_URL=postgresql://stafflow:change-me@localhost:5432/stafflow_dev
DIRECT_URL=postgresql://stafflow:change-me@localhost:5432/stafflow_dev

# false enables normal local mutations. Public portfolio deployments use true.
DEMO_MODE=false
# Must remain false; startup rejects true until quotas and cleanup exist.
DEMO_UPLOADS_ENABLED=false

# Positive byte limit used by multipart parsing and PDF validation (2 MiB).
PAYSLIP_MAX_UPLOAD_BYTES=2097152

# Optional: set all four for private payslip reads/writes or deletion retries.
# R2_ACCOUNT_ID=example-account-id
# R2_ACCESS_KEY_ID=example-access-key-id
# R2_SECRET_ACCESS_KEY=example-secret-access-key
# R2_BUCKET_NAME=stafflow-private-example

# One-shot production demo-auth bootstrap guards. The command refuses to run
# unless BOOTSTRAP_DEMO_AUTH=true and DEMO_AUTH_PASSWORD is non-empty.
BOOTSTRAP_DEMO_AUTH=false
ALLOW_BOOTSTRAP_ON_NON_EMPTY_DB=false
DEMO_ADMIN_EMAIL=admin.demo@example.com
DEMO_EMPLOYEE_EMAIL=employee.demo@example.com
DEMO_EMPLOYEE_CODE=EMP-DEMO-001
DEMO_AUTH_PASSWORD=

# Read-only deployment verification guards; set only for the named command.
SETTINGS_SINGLETON_PREFLIGHT_ACK=
DUPLICATE_INDEX_VERIFY_ACK=
DUPLICATE_INDEX_VERIFY_PHASE=
