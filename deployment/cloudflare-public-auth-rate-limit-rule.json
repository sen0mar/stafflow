{
  "description": "Stafflow public auth entry points",
  "expression": "(http.request.uri.path in {\"/auth/login\" \"/auth/invitations/accept\"})",
  "action": "block",
  "ratelimit": {
    "characteristics": ["cf.colo.id", "ip.src"],
    "period": 10,
    "requests_per_period": 5,
    "mitigation_timeout": 10
  }
}
