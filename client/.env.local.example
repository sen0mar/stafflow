# Vite client environment. Copy to client/.env.local for local overrides.
# The default local API is http://localhost:4000, so this may be omitted.
VITE_API_URL=http://localhost:4000

# In Vercel, set VITE_API_URL to the exact HTTPS API origin at build time,
# for example https://api.example.com. Do not include a path or trailing slash.
