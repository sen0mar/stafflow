generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PARTIAL
}

enum AttendanceSource {
  SELF
  ADMIN
  SYSTEM
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayslipStatus {
  ACTIVE
  DELETED
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  passwordHash          String
  role                  UserRole             @default(EMPLOYEE)
  status                UserStatus           @default(INVITED)
  lastLoginAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  employee              Employee?
  sessions              Session[]
  auditLogs             AuditLog[]           @relation("AuditLogActor")
  reviewedLeaveRequests LeaveRequest[]       @relation("LeaveRequestReviewer")
  uploadedPayslips      Payslip[]            @relation("PayslipUploader")
  passwordResetTokens   PasswordResetToken[]
  invitationTokens      InvitationToken[]    @relation("InvitationTokenUser")
  createdInvitations    InvitationToken[]    @relation("InvitationTokenCreator")

  @@index([status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Employee {
  id                String              @id @default(cuid())
  userId            String?             @unique
  departmentId      String?
  employeeCode      String              @unique
  firstName         String
  lastName          String
  jobTitle          String?
  phone             String?
  hireDate          DateTime?
  terminationDate   DateTime?
  status            EmploymentStatus    @default(ACTIVE)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  department        Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  leaveBalances     LeaveBalance[]
  payslips          Payslip[]

  @@index([departmentId])
  @@index([status])
  @@index([lastName, firstName])
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  employees   Employee[]

  @@index([isActive])
}

model AttendanceRecord {
  id           String           @id @default(cuid())
  employeeId   String
  date         DateTime
  clockInAt    DateTime?
  clockOutAt   DateTime?
  totalMinutes Int?
  status       AttendanceStatus @default(PRESENT)
  source       AttendanceSource @default(SELF)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([date])
  @@index([status])
}

model LeaveType {
  id             String         @id @default(cuid())
  name           String         @unique
  description    String?
  annualAllowance Decimal?      @db.Decimal(5, 2)
  isPaid         Boolean        @default(true)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]

  @@index([isActive])
}

model LeaveRequest {
  id           String             @id @default(cuid())
  employeeId   String
  leaveTypeId  String
  startDate    DateTime
  endDate      DateTime
  totalDays    Decimal            @db.Decimal(5, 2)
  status       LeaveRequestStatus @default(PENDING)
  reason       String?
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  employee     Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  reviewedBy   User?              @relation("LeaveRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@index([status, createdAt])
  @@index([leaveTypeId])
  @@index([reviewedById])
}

model LeaveBalance {
  id          String    @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  allocated   Decimal   @default(0) @db.Decimal(6, 2)
  used        Decimal   @default(0) @db.Decimal(6, 2)
  remaining   Decimal   @default(0) @db.Decimal(6, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)

  @@unique([employeeId, leaveTypeId, year])
  @@index([leaveTypeId])
}

model Payslip {
  id           String        @id @default(cuid())
  employeeId   String
  year         Int
  month        Int
  fileName     String
  fileSize     Int
  contentType  String
  r2ObjectKey  String
  status       PayslipStatus @default(ACTIVE)
  uploadedById String?
  uploadedAt   DateTime      @default(now())
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employee     Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy   User?         @relation("PayslipUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([employeeId, year, month])
  @@index([employeeId, year, month])
  @@index([status])
  @@index([uploadedById])
}

model CompanySettings {
  id        String   @id @default(cuid())
  name      String
  timezone  String   @default("UTC")
  locale    String   @default("en-US")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceSettings {
  id                     String   @id @default(cuid())
  workdayMinutes         Int      @default(480)
  workdayStart           String   @default("09:00")
  workdayEnd             String   @default("17:00")
  weeklyWorkingDays      Int[]    @default([1, 2, 3, 4, 5])
  lateGracePeriodMinutes Int      @default(0)
  allowEmployeeClockIn   Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model LeaveSettings {
  id                         String   @id @default(cuid())
  defaultAnnualAllowanceDays Decimal  @default(0) @db.Decimal(5, 2)
  allowNegativeBalance       Boolean  @default(false)
  policyText                 String?  @db.Text
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model InvitationToken {
  id          String    @id @default(cuid())
  userId      String?
  email       String
  tokenHash   String    @unique
  role        UserRole   @default(EMPLOYEE)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  user        User?     @relation("InvitationTokenUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation("InvitationTokenCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@index([createdById])
  @@index([expiresAt])
}
