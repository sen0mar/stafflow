# Render API environment. Render owns PORT; do not override it in the service.
NODE_ENV=production
# Exact HTTPS Vercel/custom frontend origin; no path or wildcard.
CLIENT_URL=https://app.example.com

# Neon pooled runtime URL. DIRECT_URL is for Prisma migration commands only.
DATABASE_URL=postgresql://example:change-me@pooled.example.com/stafflow
DIRECT_URL=postgresql://example:change-me@direct.example.com/stafflow

# Required public-demo posture. Use DEMO_MODE=false only for a private workspace.
DEMO_MODE=true
# Startup rejects true until enforceable quotas and automatic cleanup exist.
DEMO_UPLOADS_ENABLED=false
PAYSLIP_MAX_UPLOAD_BYTES=2097152

# Optional at startup; configure all four together for private payslip reads in
# any deployment or writes in a mutable deployment. The deletion cron also needs them.
# R2_ACCOUNT_ID=example-account-id
# R2_ACCESS_KEY_ID=example-access-key-id
# R2_SECRET_ACCESS_KEY=example-secret-access-key
# R2_BUCKET_NAME=stafflow-private-example

# VITE_API_URL belongs to the Vercel client environment, not this API file.
# Render cron services do not need CLIENT_URL, DIRECT_URL, demo, or upload-size values.
